<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Прочитані книги</h1>
  <%= link_to "Всі книги", books_path, class: "btn btn-outline-secondary" %>
</div>

<table class="table table-striped">
  <thead class="table-dark">
    <tr>
      <th>Назва</th>
      <th>Жанр</th>
      <th>Рейтинг</th>
      <th>Статус</th>
      <th>Дії</th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= link_to book.title, book %></td>
        <td><%= book.genre %></td>
        <td><%= book.rating %></td>
        <td><%= status_badge(book) %></td>
        <td>
          <%= link_to "Переглянути", book, class: "btn btn-sm btn-outline-primary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
