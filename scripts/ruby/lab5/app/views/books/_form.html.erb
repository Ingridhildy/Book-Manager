<%= form_with(model: book) do |f| %>
  <% if book.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Назва", class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :genre, "Жанр", class: "form-label" %>
    <%= f.select :genre, Genre.pluck(:name), { include_blank: "— оберіть жанр —" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :publisher, "Видавництво", class: "form-label" %>
    <%= f.text_field :publisher, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :published_date, "Дата публікації", class: "form-label" %>
    <%= f.date_field :published_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :pages, "Кількість сторінок", class: "form-label" %>
    <%= f.number_field :pages, min: 1, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, "Рейтинг (0–10)", class: "form-label" %>
    <%= f.number_field :rating, min: 0, max: 10, step: 0.1, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :status, "Статус", class: "form-label" %>
    <%= f.select :status, Book.statuses.keys, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :isbn, "ISBN", class: "form-label" %>
    <%= f.text_field :isbn, class: "form-control", placeholder: "978-X-XXX-XXXXX-X" %>
  </div>

  <%= f.submit "Зберегти", class: "btn btn-primary" %>
<% end %>
