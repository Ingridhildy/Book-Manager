<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Каталог книг</h1>
  <%= link_to "Додати книгу", new_book_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped">
  <thead class="table-dark">
    <tr>
      <th>Назва</th>
      <th>Жанр</th>
      <th>Видавництво</th>
      <th>Дата публікації</th>
      <th>Сторінок</th>
      <th>Рейтинг</th>
      <th>Статус</th>
      <th>Дії</th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= link_to book.title, book %></td>
        <td><%= book.genre %></td>
        <td><%= book.publisher %></td>
        <td><%= book.published_date %></td>
        <td><%= book.pages %></td>
        <td><%= book.rating %></td>
        <td><%= status_badge(book) %></td>
        <td>
          <%= link_to "Редагувати", edit_book_path(book), class: "btn btn-sm btn-outline-secondary" %>
          <%= button_to "Видалити", book, method: :delete, data: { turbo_confirm: "Видалити цю книгу?" }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
