<div class="card" style="max-width: 400px;">
  <div class="card-body">
    <h2 class="card-title"><%= @author.name %></h2>
    <p class="card-text"><strong>ID книги:</strong> <%= @author.book_id %></p>
  </div>
</div>
<div class="mt-3">
  <%= link_to "Редагувати", edit_author_path(@author), class: "btn btn-outline-secondary" %>
  <%= link_to "До книги", book_path(@author.book_id), class: "btn btn-link" %>
</div>
